---
pagination:
  data: chartsManifest.charts
  size: 1
  alias: c
permalink: "/chart-previews/{{ c.id }}/index.html"
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Playfair+Display:ital,wght@0,500;0,600;1,500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/tokens.css">
<link rel="stylesheet" href="/css/layout.css">
<link rel="stylesheet" href="/css/components.css">
<link rel="stylesheet" href="/css/utilities.css">
<style>
  html { height: 100%; }
  body { margin: 0; min-height: 100%; box-sizing: border-box;
         display: flex; flex-direction: column; align-items: center; justify-content: flex-start;
         gap: 28px; padding: 40px 32px;
         background: var(--color-bg-primary) !important; background-attachment: initial !important;
         font-family: var(--font-primary); }
  .preview-stage { width: 100%; max-width: {{ c.previewWidth }}px; }
  .preview-variants { display: flex; flex-wrap: wrap; gap: 32px 28px;
         align-items: flex-start; justify-content: center; width: 100%; }
  .preview-variant { margin: 0; display: flex; flex-direction: column; gap: 12px; max-width: 100%; }
  .preview-variant .preview-stage { max-width: none; }
  .preview-variant figcaption { font-size: 11px; letter-spacing: .1em; text-transform: uppercase;
         color: var(--text-muted, #b3a6c8); text-align: center; }
</style>
</head>
<body>
{% if c.variants %}
  <div class="preview-variants">
  {% for v in c.variants %}
    <figure class="preview-variant" style="width:{{ v.previewWidth or c.previewWidth }}px;">
      <div class="preview-stage">{{ v.snippet | safe }}</div>
      <figcaption>{{ v.label }}</figcaption>
    </figure>
  {% endfor %}
  </div>
{% endif %}
{% if c.states %}
  <div class="preview-variants preview-states">
  {% for s in c.states %}
    <figure class="preview-variant" style="width:{{ s.previewWidth or c.previewWidth }}px;">
      <div class="preview-stage">{{ s.snippet | safe }}</div>
      <figcaption>{{ s.label }}{% if s.note %} · {{ s.note }}{% endif %}</figcaption>
    </figure>
  {% endfor %}
  </div>
{% endif %}
{% if not c.variants and not c.states %}
  <div class="preview-stage">
  {{ c.snippet | safe }}
  </div>
{% endif %}
</body>
</html>
