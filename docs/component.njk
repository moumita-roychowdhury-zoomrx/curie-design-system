---
layout: base.njk
nav: components
pagination:
  data: manifest.components
  size: 1
  alias: c
permalink: "/components/{{ c.id }}/"
eleventyComputed:
  title: "{{ c.name }}"
  componentId: "{{ c.id }}"
---
<div class="ds-eyebrow">{{ c.category }} · {{ c.status }}</div>
<h1 class="ds-title">{{ c.name }}</h1>
<p class="ds-lede">{{ c.purpose }}</p>

<iframe class="ds-preview-frame" src="/previews/{{ c.id }}/" height="{{ c.previewHeight }}" title="{{ c.name }} preview" loading="lazy"></iframe>
{% if c.previewNote %}<div class="ds-meta-line">{{ c.previewNote }}</div>{% endif %}
{% if c.variants %}<div class="ds-meta-line">Variants: {% for v in c.variants %}<code>{{ v.label }}</code>{% if not loop.last %} · {% endif %}{% endfor %}</div>{% endif %}
<div class="ds-meta-line">Source of truth: <code>{{ c.sourcePage }}</code> · styling in <code>components.css</code></div>

<div class="ds-usage-grid">
  <div class="ds-usage do"><strong>When to use</strong>{{ c.whenToUse }}</div>
  <div class="ds-usage dont"><strong>When not to use</strong>{{ c.whenNotToUse }}</div>
</div>

<h2 class="ds-section">Anatomy</h2>
<div class="ds-anatomy">
  {% for cls in c.anatomy %}<code>.{{ cls }}</code>{% endfor %}
</div>
<p class="ds-meta-line">{{ c.interactions }}</p>

<h2 class="ds-section">Markup</h2>
<pre class="ds-code">{{ c.snippet }}</pre>
