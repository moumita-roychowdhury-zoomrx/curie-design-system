---
layout: base.njk
nav: mobile
pagination:
  data: mobileManifest.components
  size: 1
  alias: c
permalink: "/mobile/{{ c.id }}/"
eleventyComputed:
  title: "{{ c.name }} · Mobile"
  mobileComponentId: "{{ c.id }}"
---
<div class="ds-eyebrow">{{ c.category }} · mobile · {{ c.status }}</div>
<h1 class="ds-title">{{ c.name }}</h1>
<p class="ds-lede">{{ c.purpose }}</p>

<div class="ds-phone-row">
  <figure class="ds-phone">
    <div class="ds-phone__screen" style="height:{{ c.previewHeight or 640 }}px">
      <iframe src="/mobile-previews/{{ c.id }}/" title="{{ c.name }} mobile preview" loading="lazy"></iframe>
    </div>
    <figcaption>{{ c.name }} · 390px viewport</figcaption>
  </figure>
</div>

{% if c.mobileTreatment %}<div class="ds-meta-line">Mobile treatment: {{ c.mobileTreatment }}</div>{% endif %}
{% if c.desktopEquivalent %}<div class="ds-meta-line">Desktop equivalent: <a href="/components/{{ c.desktopEquivalent }}/"><code>{{ c.desktopEquivalent }}</code></a></div>{% endif %}
<div class="ds-meta-line">Source of truth: <code>{{ c.sourcePage }}</code> · styling in <code>responsive.css</code></div>

<div class="ds-usage-grid">
  <div class="ds-usage do"><strong>When to use</strong>{{ c.whenToUse }}</div>
  <div class="ds-usage dont"><strong>When not to use</strong>{{ c.whenNotToUse }}</div>
</div>

<h2 class="ds-section">Anatomy</h2>
<div class="ds-anatomy">
  {% for cls in c.anatomy %}<code>.{{ cls }}</code>{% endfor %}
</div>
<p class="ds-meta-line">{{ c.interactions }}</p>

<h2 class="ds-section">Markup</h2>
<pre class="ds-code">{{ c.snippet }}</pre>

<style>
  .ds-phone-row { display: flex; flex-wrap: wrap; gap: 28px; margin: 20px 0 8px; }
  .ds-phone { margin: 0; display: flex; flex-direction: column; gap: 10px; align-items: center; }
  .ds-phone__screen {
    box-sizing: content-box;
    width: 390px; border-radius: 28px; overflow: hidden;
    border: 8px solid #241f3d; box-shadow: 0 18px 50px rgba(0,0,0,0.45);
    background: #140d2c;
  }
  .ds-phone__screen iframe { width: 100%; height: 100%; border: 0; display: block; }
  .ds-phone figcaption { font-size: 12px; letter-spacing: .08em; text-transform: uppercase; color: var(--text-muted, #b3a6c8); }
</style>
