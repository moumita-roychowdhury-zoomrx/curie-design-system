---
pagination:
  data: mobileManifest.components
  size: 1
  alias: c
permalink: "/mobile-previews/{{ c.id }}/index.html"
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Playfair+Display:ital,wght@0,500;0,600;1,500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/tokens.css">
<link rel="stylesheet" href="/css/layout.css">
<link rel="stylesheet" href="/css/components.css">
<link rel="stylesheet" href="/css/utilities.css">
<link rel="stylesheet" href="/css/responsive.css">
<link rel="stylesheet" href="/mobile-preview-extras.css">
<style>
  /* Mobile specimen stage. The iframe that embeds this page is rendered at a
     phone width (<=600px) on the component page, so responsive.css's
     @media (max-width:600px) block is active here and the .m-* rules apply.
     A pg- body class satisfies the mobile chrome scoping + the base guard. */
  html, body { height: 100%; }
  body { margin: 0; background: var(--color-bg-primary) !important; background-attachment: initial !important;
         font-family: var(--font-primary); color: #fff; }
  /* Trim the app-bar / tab-bar reservation for in-flow content specimens so they
     sit at the top of the frame; chrome specimens render outside .m-view. */
  body[class^="pg-"] .m-view { padding: 20px 22px 24px !important; max-width: none !important; margin: 0 !important; }
  /* The golden pages carry this same override page-locally: the shared
     `body[class^="pg-"] .m-drawer/.m-sheet { visibility:hidden }` rule out-specifies the
     bare `.is-open` rule, so open overlays need a more-specific selector to become visible. */
  body[class^="pg-"] .m-drawer.is-open { visibility: visible; opacity: 1; }
  body[class^="pg-"] .m-sheet.is-open { visibility: visible; }
  body[class^="pg-"] .m-foryou__menu.is-open,
  body[class^="pg-"] .m-sources__menu.is-open { display: block; }
</style>
</head>
<body class="pg-briefs">
{% if c.chrome %}
{{ c.snippet | safe }}
{% else %}
<div class="m-view">
{{ c.snippet | safe }}
</div>
{% endif %}
</body>
</html>
